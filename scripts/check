#!/bin/sh
set -eu

python3 scripts/check_versions.py
buf lint
buf format --diff --exit-code api
head_commit="$(git rev-parse HEAD)"
release_tag="v$(tr -d '\n' < VERSION)"
baseline_tag=""
for candidate in $(git tag --merged HEAD --list 'v[0-9]*.[0-9]*.[0-9]*' --sort=-version:refname); do
  case "$candidate" in
    *-*) continue ;;
  esac
  # On the release commit, compare against the preceding release rather than
  # against the candidate tag itself. Do not skip an older tag merely because
  # the dirty worktree happens to be based directly on its commit.
  if [ "$candidate" = "$release_tag" ] &&
    [ "$(git rev-list -n 1 "$candidate")" = "$head_commit" ]; then
    continue
  fi
  baseline_tag="$candidate"
  break
done
if [ -n "$baseline_tag" ]; then
  python3 scripts/check_buf_breaking.py \
    --against ".git#tag=$baseline_tag,subdir=api" \
    --baseline-tag "$baseline_tag" \
    --version "$(tr -d '\n' < VERSION)"
else
  echo "Skipping the Buf compatibility check; no prior plain SemVer tag is reachable." >&2
fi
# The Python Connect generator is intentionally installed from the locked core
# development environment because the BSR-hosted plugin lags the 0.11 runtime.
uv sync --project core/py --locked
# Remote BSR plugins are authenticated in trusted CI. Fork PRs and local
# checkouts often have no BUF_TOKEN and share a strict anonymous rate limit;
# those gates still validate the checked-in descriptor and compile/test every
# generated consumer. Set TEMPORALESS_REQUIRE_BUF_GENERATE=1 to force a local
# regeneration (and fail on any remote-plugin error).
if [ -n "${BUF_TOKEN:-}" ] || [ "${TEMPORALESS_REQUIRE_BUF_GENERATE:-0}" = "1" ]; then
  scripts/generate
else
  echo "Skipping remote Buf plugin regeneration without BUF_TOKEN; set TEMPORALESS_REQUIRE_BUF_GENERATE=1 to force it." >&2
fi
scripts/public-surface-check
descriptor_file="$(mktemp)"
trap 'rm -f "$descriptor_file"' EXIT HUP INT TERM
buf build api --as-file-descriptor-set -o "$descriptor_file"
if ! cmp -s "$descriptor_file" core/ts/src/gen/temporaless/v1/temporaless_descriptor.binpb; then
  echo "core/ts/src/gen/temporaless/v1/temporaless_descriptor.binpb is stale; run scripts/generate." >&2
  exit 1
fi
if [ "${CI:-}" = "true" ]; then
  # A clean CI checkout must remain clean after formatting/code generation.
  # Local feature branches may intentionally be validating uncommitted schema
  # changes, so this assertion is CI-only.
  git diff --exit-code -- \
    api \
    core/go/gen \
    core/py/src/buf \
    core/py/src/temporaless/v1 \
    core/ts/src/gen
  generated_untracked="$(git ls-files --others --exclude-standard -- \
    api \
    core/go/gen \
    core/py/src/buf \
    core/py/src/temporaless/v1 \
    core/ts/src/gen)"
  if [ -n "$generated_untracked" ]; then
    echo "Buf generation produced untracked files:" >&2
    echo "$generated_untracked" >&2
    exit 1
  fi
fi
if command -v npm >/dev/null 2>&1; then
  npm run check
else
  echo "Skipping TypeScript client checks; npm is not on PATH." >&2
fi
# Go is first-class and always part of the release gate. Generated protobuf
# packages under core/go/gen are Buf-owned and excluded from gofmt.
unformatted="$(gofmt -l . | grep -v '^core/go/gen/' || true)"
if [ -n "$unformatted" ]; then
  echo "gofmt needs to run on:" >&2
  echo "$unformatted" >&2
  exit 1
fi
go mod tidy -diff
go vet ./...
go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2 run ./...
go test -race ./...
if command -v cargo >/dev/null 2>&1; then
  cargo fmt --all --check
  cargo clippy --workspace --all-targets --locked -- -D warnings
  cargo test --workspace --locked
else
  echo "Skipping the experimental Rust SDK locally; CI validates it with the pinned rust-toolchain.toml." >&2
fi
uv run --project core/py ruff format --check core/py/src core/py/tests core/py/benchmarks examples/py scripts/check_buf_breaking.py scripts/check_versions.py scripts/set_version.py
uv run --project core/py ruff check core/py/src core/py/tests core/py/benchmarks examples/py scripts/check_buf_breaking.py scripts/check_versions.py scripts/set_version.py
uv run --project core/py ty check core/py/src/temporaless core/py/benchmarks examples/py scripts/check_buf_breaking.py scripts/check_versions.py scripts/set_version.py --exclude='**/temporaless/v1/**' --exclude='**/buf/**'
uv run --project core/py pytest core/py/tests
uv sync --project adapters/py/connectworkflow --locked
uv run --project adapters/py/connectworkflow ruff format --check adapters/py/connectworkflow/src adapters/py/connectworkflow/tests
uv run --project adapters/py/connectworkflow ruff check adapters/py/connectworkflow/src adapters/py/connectworkflow/tests
uv run --project adapters/py/connectworkflow ty check adapters/py/connectworkflow/src adapters/py/connectworkflow/tests
uv run --project adapters/py/connectworkflow pytest adapters/py/connectworkflow/tests
uv sync --project adapters/py/temporalcompat --locked
uv run --project adapters/py/temporalcompat ruff format --check adapters/py/temporalcompat/src adapters/py/temporalcompat/tests
uv run --project adapters/py/temporalcompat ruff check adapters/py/temporalcompat/src adapters/py/temporalcompat/tests
uv run --project adapters/py/temporalcompat ty check adapters/py/temporalcompat/src adapters/py/temporalcompat/tests
uv run --project adapters/py/temporalcompat pytest adapters/py/temporalcompat/tests
uv sync --project adapters/py/prefectcompat --locked
uv run --project adapters/py/prefectcompat ruff format --check adapters/py/prefectcompat/src adapters/py/prefectcompat/tests
uv run --project adapters/py/prefectcompat ruff check adapters/py/prefectcompat/src adapters/py/prefectcompat/tests
uv run --project adapters/py/prefectcompat ty check adapters/py/prefectcompat/src adapters/py/prefectcompat/tests
# Prefect's temporary test server otherwise emits shutdown INFO logs after
# pytest closes its captured stream, creating a misleading logging traceback
# despite a successful suite. Tests do not assert logging behavior.
PREFECT_LOGGING_LEVEL=ERROR \
  PREFECT_LOGGING_TO_API_WHEN_MISSING_FLOW=ignore \
  uv run --project adapters/py/prefectcompat pytest adapters/py/prefectcompat/tests
uv sync --project adapters/py/indexstore --locked
uv run --project adapters/py/indexstore ruff format --check adapters/py/indexstore/src adapters/py/indexstore/tests
uv run --project adapters/py/indexstore ruff check adapters/py/indexstore/src adapters/py/indexstore/tests
uv run --project adapters/py/indexstore ty check adapters/py/indexstore/src adapters/py/indexstore/tests
uv run --project adapters/py/indexstore pytest adapters/py/indexstore/tests
